# PostgreSQL connection string. PostGIS extension is required.
DATABASE_URL="postgresql://postgres:<password>@127.0.0.1:5432/shareable?schema=public"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required in production — the app fails fast on boot if missing.
NEXTAUTH_SECRET=""

# Where uploaded images are stored on disk. In production: /var/lib/shareable/uploads
UPLOAD_DIR="./uploads"

# Deterministic seed for SHA-256 jittering of public coordinates.
# Generate with: openssl rand -hex 32
JITTER_SEED=""

# Nominatim proxy — required by their ToS. Format: "AppName/version (contact)"
GEOCODER_USER_AGENT="shareable/1.0 (you@example.com)"

# SMTP for transactional emails (optional — if unset, email sending is silently skipped)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Shareable <noreply@example.com>"

# Enable Prisma query logs (dev only — never in prod)
# DEBUG_PRISMA="true"
